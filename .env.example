# Приклад файлу налаштувань для Assistant T800.
# Скопіюйте цей файл у `.env` та заповніть реальними значеннями:
#   cp .env.example .env
# Файл `.env` НЕ комітиться у репозиторій (додано до .gitignore).

# Ідентифікатор моделі для pydantic-ai у форматі `provider:model`.
# Значення за замовчуванням задано у `src/assistant_t800/config.py`
# (`google-gla:gemini-3.1-flash-lite`), тому змінну можна не вказувати.
# Розкоментуйте та змініть, якщо хочете використати іншу модель.
# ASSISTANT_T800_MODEL=google-gla:gemini-3.1-flash-lite

# API-ключ Google AI Studio (Generative Language API), потрібний для
# провайдера `google-gla`. Отримати ключ можна на https://aistudio.google.com/apikey
# Замініть `xxx` на ваш реальний ключ.
GOOGLE_API_KEY=xxx
