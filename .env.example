# Example configuration file for Assistant T800.
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
# The `.env` file must NOT be committed to the repository.

# pydantic-ai model identifier in `provider:model` format.
# The default value is defined in `src/assistant_t800/config.py`,
# so this variable may be omitted.
# Uncomment and change it if you want to use another model.
# ASSISTANT_T800_MODEL=google-gla:gemini-3.1-flash-lite

# Google AI Studio API key, required for the `google-gla` provider.
# Get a key at https://aistudio.google.com/apikey
# Replace `xxx` with your real key.
GOOGLE_API_KEY=xxx
