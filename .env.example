# Example configuration file for Assistant T800.
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
# The `.env` file must NOT be committed to the repository.

# pydantic-ai model identifier in `provider:model` format.
# The default value is defined in `src/assistant_t800/config.py`,
# so this variable may be omitted.
ASSISTANT_T800_MODEL=google-gla:gemini-3.1-flash-lite

# Google AI Studio API key, required for the `google-gla` provider.
# Get a key at https://aistudio.google.com/apikey
# Replace `xxx` with your real key.
GOOGLE_API_KEY=xxx

# Optional AI-mode tuning. These affect ONLY the AI/TUI layer
# (`ai/agent.py`, `ai/utils.py`); the classic CLI ignores them.
# Defaults live in `src/assistant_t800/config.py`, so both may be omitted.
# Variable names are case-insensitive and map to the Settings field names.

# Max number of chat messages kept in AI conversation history.
# MAX_HISTORY_MESSAGES=10

# Max number of contacts returned by an AI tool call.
# MAX_CONTACTS_IN_TOOL_RETURN=25
